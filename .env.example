# 🤖 AI Software Factory - Environment Configuration

# ============================================================================
# 🔑 LLM API KEYS
# ============================================================================

# OpenAI (GPT-4, GPT-4o, etc.)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude 3 Opus, Sonnet, Haiku)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google (Gemini Pro, Ultra)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Azure OpenAI
# Get key: https://portal.azure.com
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# AWS (Bedrock - Claude on Bedrock)
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Ollama (Local - Free!)
# Install: https://ollama.ai
OLLAMA_URL=http://localhost:11434
# No API key needed for local!


# ============================================================================
# 🗄️ DATABASE
# ============================================================================

# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_factory

# MongoDB (optional)
MONGODB_URL=mongodb://localhost:27017/ai_factory

# Redis (for caching)
REDIS_URL=redis://localhost:6379/0


# ============================================================================
# 💳 PAYMENTS
# ============================================================================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# PayPal (optional)
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx


# ============================================================================
# 📧 EMAIL
# ============================================================================

# SendGrid
SENDGRID_API_KEY=SG.xxx

# Resend (recommended)
RESEND_API_KEY=re_xxx

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password


# ============================================================================
# ☁️ DEPLOYMENT
# ============================================================================

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# Netlify
NETLIFY_AUTH_TOKEN=your-netlify-token

# Railway
RAILWAY_TOKEN=your-railway-token

# DigitalOcean
DO_TOKEN=your-do-token


# ============================================================================
# 🔒 SECURITY
# ============================================================================

# Generate a secure secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# JWT
JWT_SECRET_KEY=your-jwt-secret
JWT_EXPIRY_HOURS=24


# ============================================================================
# ⚙️ APPLICATION
# ============================================================================

# Environment
DEBUG=true
NODE_ENV=development

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_MONITORING=true
ENABLE_RATE_LIMITING=true


# ============================================================================
# 📊 ANALYTICS
# ============================================================================

# PostHog
POSTHOG_API_KEY=phc_xxx

# Mixpanel
MIXPANEL_TOKEN=your-mixpanel-token

# Google Analytics
GA_MEASUREMENT_ID=G-xxx


# ============================================================================
# 🏗️ AI FACTORY SETTINGS
# ============================================================================

# Default LLM provider (openai, anthropic, google, azure, ollama)
DEFAULT_LLM_PROVIDER=openai

# Planning model (for reasoning tasks)
PLANNING_MODEL=gpt-4o

# Coding model (for code generation)
CODING_MODEL=gpt-4o

# Max tokens per request
MAX_TOKENS=4096

# Temperature (0-1)
TEMPERATURE=0.7

# Enable parallel processing
PARALLEL_ENABLED=true

# Max concurrent agents
MAX_CONCURRENT_AGENTS=5


# ============================================================================
# 🚀 QUICK START
# ============================================================================

# 1. Copy this file to .env
# 2. Fill in your API keys
# 3. Run: python main.py "Build a SaaS app"

# For local development without API keys:
# - Install Ollama: https://ollama.ai
# - Run: ollama serve
# - Set DEFAULT_LLM_PROVIDER=ollama
